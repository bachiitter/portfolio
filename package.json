{
  "name": "portfolio",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next build && npx serve out",
    "lint:check": "eslint . --cache --cache-strategy content --ignore-path .gitignore",
    "lint:fix": "eslint . --fix --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,cjs,mjs,json,md,mdx}\" --cache",
    "format:fix": "prettier --write \"**/*.{ts,tsx,cjs,mjs,json,md,mdx,html}\" --cache",
    "check": "pnpm lint:check && pnpm format:check && pnpm typecheck",
    "fix": "pnpm lint:fix && pnpm format:fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.0.1",
    "class-variance-authority": "^0.6.0",
    "clsx": "^1.2.1",
    "framer-motion": "^10.12.16",
    "lucide-react": "^0.241.0",
    "next": "13.4.4",
    "next-themes": "^0.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-wrap-balancer": "^0.5.0",
    "swr": "^2.1.5",
    "tailwind-merge": "^1.13.1",
    "tailwindcss-animate": "^1.0.5"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.0.2",
    "@types/node": "20.2.5",
    "@types/react": "18.2.9",
    "@types/react-dom": "18.2.4",
    "@typescript-eslint/eslint-plugin": "^5.59.9",
    "@typescript-eslint/parser": "^5.59.9",
    "autoprefixer": "10.4.14",
    "eslint": "8.42.0",
    "eslint-config-next": "13.4.4",
    "eslint-config-prettier": "^8.8.0",
    "postcss": "8.4.24",
    "prettier": "2.8.8",
    "prettier-plugin-tailwindcss": "^0.3.0",
    "tailwindcss": "3.3.2",
    "typescript": "5.1.3"
  }
}
